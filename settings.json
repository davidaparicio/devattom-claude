{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "MAX_THINKING_TOKENS": "31999",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "90",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "MAX_MCP_OUTPUT_TOKENS": "50000",
    "GIT_AUTHOR_NAME": "Thomas ROUSSELIN",
    "GIT_COMMITTER_NAME": "Thomas ROUSSELIN",
    "GIT_AUTHOR_EMAIL": "devattom@gmail.com",
    "GIT_COMMITTER_EMAIL": "devattom@gmail.com"
  },
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Bash(su :*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(poweroff:*)",
      "Bash(halt:*)",
      "Bash(systemctl :*)",
      "Bash(service :*)",
      "Bash(mount :*)",
      "Bash(umount :*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(dd :*)",
      "Bash(parted:*)",
      "Bash(iptables :*)",
      "Bash(ufw :*)",
      "Bash(chmod 777:*)",
      "Bash(chown :*)",
      "Bash(apt :*)",
      "Bash(apt-get :*)",
      "Bash(dpkg :*)",
      "Bash(snap :*)",
      "Bash(npm install -g:*)",
      "Bash(npm i -g:*)",
      "Bash(pnpm add -g:*)",
      "Bash(yarn global :*)",
      "Bash(eval :*)",
      "Bash(killall :*)",
      "Bash(pkill :*)",
      "Bash(kill -9 :*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/run-hook hook-git-context.ts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/run-hook command-validator/src/cli.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/run-hook hook-ts-quality-gate.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/run-hook hook-completion-handler.ts"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/run-hook --sound need-human.mp3"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node --experimental-strip-types $HOME/.claude/scripts/statusline.ts"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "upstash.com",
        "pypi.org"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "//tmp",
        "."
      ],
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.config/gcloud",
        "~/.docker/config.json",
        "~/.netrc",
        "~/.npmrc"
      ]
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium"
}
